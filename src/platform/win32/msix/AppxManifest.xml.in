<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest template for the packaged (full-trust Win32) build of Clipp.
  @TOKENS@ are substituted by scripts/package_windows_msix.ps1.

  Two Applications, because Windows bakes the GUI-vs-console subsystem into the PE
  header at link time and a single PE can't be both:
    - clippmain.exe: the GUI tray app (/SUBSYSTEM:WINDOWS). The visible Start entry.
    - clipp.exe: the console twin (/SUBSYSTEM:CONSOLE; this is the former
                        clipp.com renamed, since MSIX requires Executable to end in
                        .exe). Hidden from Start, exposed on PATH as `clipp` via an
                        App Execution Alias. This is what gives real pipe/stdin/exit-
                        code behavior from the command line; the GUI exe cannot.
  The packaging script does the rename: build clipp.exe -> clippmain.exe, build
  clipp.com -> clipp.exe.

  Other notes:
    - EntryPoint="Windows.FullTrustApplication" + rescap:runFullTrust: both run
      UNSANDBOXED (not AppContainer), so networking/clipboard/DPAPI work as unpackaged.
    - Registry is copy-on-write, though: the app READS the real HKCU (merged) but its
      WRITES land in a per-package overlay invisible to the rest of the system. So the
      app's HKCU\...\Run autostart never reaches the logon scan (which reads the real
      hive). windows.startupTask below is the autostart that actually fires; the app
      should enable/disable it via the Windows.ApplicationModel.StartupTask WinRT API
      when packaged (AutoStart.cpp's Run-key path is a no-op here).
    - Logos are PNG (MSIX does not use .ico for tiles/Start/taskbar). The manifest
      names the base logos; Windows resolves the scale-*/targetsize-*/altform-unplated
      variants via resources.pri (generated by makepri at pack time).
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <Identity
    Name="@IDENTITY_NAME@"
    Publisher="@PUBLISHER@"
    Version="@VERSION@"
    ProcessorArchitecture="@ARCH@" />

  <Properties>
    <DisplayName>Clipp</DisplayName>
    <PublisherDisplayName>@PUBLISHER_DISPLAY_NAME@</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="privateNetworkClientServer" />
    <Capability Name="internetClientServer" />
  </Capabilities>

  <Applications>
    <Application Id="Clipp" Executable="clippmain.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Clipp"
        Description="Share your clipboard across your trusted devices on the local network."
        BackgroundColor="#2D2D30"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png">
        <uap:DefaultTile Square71x71Logo="Images\Square71x71Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <uap5:Extension Category="windows.startupTask" Executable="clippmain.exe" EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask TaskId="ClippAutoStart" Enabled="false" DisplayName="Clipp" />
        </uap5:Extension>
      </Extensions>
    </Application>

    <Application Id="ClippCli" Executable="clipp.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        AppListEntry="none"
        DisplayName="Clipp (CLI)"
        Description="Clipp command-line interface."
        BackgroundColor="#2D2D30"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png" />
      <Extensions>
        <uap5:Extension Category="windows.appExecutionAlias">
          <uap5:AppExecutionAlias>
            <uap5:ExecutionAlias Alias="clipp.exe" />
          </uap5:AppExecutionAlias>
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>
</Package>
