IDI_CLIPP_ICON          ICON                    "resources\\Clipboard4DevAspect-macos-1024-transparent.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Device-type symbol font
//
// The stripped-down "Clipp Symbols" Nerd Fonts subset is embedded directly in
// the exe (not shipped as a loose asset) so the unpackaged zip is a single
// self-contained binary. It is loaded at runtime via DirectWrite -> rasterized
// to bitmaps (see win32/SymbolGlyphs.cpp); system XAML can't reference a font
// from the PE resource section, hence the rasterize. Skipped for the .com shim,
// which never renders UI. Generated by tools/symbols/build_symbols_font.py.
//
#ifndef CLIPP_RESOURCE_SHIM
// Name is UNQUOTED on purpose: rc.exe bakes the quotes into the resource name if
// quoted, and FindResourceW(L"CLIPP_SYMBOLS_FONT") would then miss. Unquoted, rc
// stores it as the (case-insensitive) name we look up at runtime.
CLIPP_SYMBOLS_FONT       RCDATA                  "resources\\ClippSymbols.ttf"
#endif

// The About box renders the app icon (IDI_CLIPP_ICON above) decoded via WIC, so there
// is no longer a separate ~720KB About PNG embedded here (see win32/AboutPage.cpp,
// LoadAppIconBitmap). The PNG master is retained in src/resources for the macOS/iOS
// asset pipelines.

/////////////////////////////////////////////////////////////////////////////
//
// Version
//

#ifdef CLIPP_RESOURCE_SHIM
#define CLIPP_RESOURCE_FILE_DESCRIPTION "clipp.com"
#define CLIPP_RESOURCE_INTERNAL_NAME "clipp.com"
#define CLIPP_RESOURCE_ORIGINAL_FILENAME "clipp.com"
#else
#define CLIPP_RESOURCE_FILE_DESCRIPTION "clipp.exe"
#define CLIPP_RESOURCE_INTERNAL_NAME "clipp.exe"
#define CLIPP_RESOURCE_ORIGINAL_FILENAME "clipp.exe"
#endif

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @CLIPP_VERSION_MAJOR@,@CLIPP_VERSION_MINOR@,@CLIPP_VERSION_PATCH@,@CLIPP_VERSION_BUILD@
 PRODUCTVERSION @CLIPP_VERSION_MAJOR@,@CLIPP_VERSION_MINOR@,@CLIPP_VERSION_PATCH@,@CLIPP_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Marton Anka"
            VALUE "FileDescription", CLIPP_RESOURCE_FILE_DESCRIPTION
            VALUE "FileVersion", "@CLIPP_VERSION@"
            VALUE "InternalName", CLIPP_RESOURCE_INTERNAL_NAME
            VALUE "LegalCopyright", "Copyright (C) 2026 Marton Anka"
            VALUE "OriginalFilename", CLIPP_RESOURCE_ORIGINAL_FILENAME
            VALUE "ProductName", "clipp"
            VALUE "ProductVersion", "@CLIPP_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

#endif    // English (United States) resources
